```ts
// utils.ts
import { create as createDeptApi, list as fetchDeptListApi } from "./api";

async function fetchFlatOrgs() {
  const data = await fetchDeptListApi();
  return data ?? [];
}

export async function create(values: OrgFormValues) {
  await createDeptApi({ deptName: values.deptName.trim(), ... });
}

