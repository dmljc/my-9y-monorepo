{
	"name": "frontend-project-template",
	"license": "ISC",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.5.1",
	"scripts": {
		"admin:dev": "node scripts/run-app-script.mjs admin dev",
		"admin:build": "node scripts/run-app-script.mjs admin build",
		"admin:preview": "node scripts/run-app-script.mjs admin preview",
		"ipad:dev": "node scripts/run-app-script.mjs ipad dev",
		"ipad:build": "node scripts/run-app-script.mjs ipad build",
		"clean:all-dists": "pnpm -r exec rm -rf dist",
		"clean:all-node_modules": "pnpm -r exec rm -rf node_modules && rm -rf node_modules",
		"lint": "biome check",
		"lint:fix": "biome check --write --unsafe",
		"prepare": "husky",
		"lint:lint-staged": "lint-staged",
		"commit": "git-cz",
		"ncu": "ncu",
		"ncu:update": "ncu -u"
	},
	"lint-staged": {
		"*.{js,ts,tsx,cjs,mjs}": [
			"biome check --write --unsafe"
		],
		"*.{json,jsonc}": [
			"biome check --write --unsafe"
		],
		"*.{css,scss}": [
			"biome check --write --unsafe"
		]
	},
	"config": {
		"commitizen": {
			"path": "node_modules/cz-git"
		}
	},
	"pnpm": {
		"supportedArchitectures": {
			"os": [
				"current",
				"linux"
			],
			"cpu": [
				"current",
				"x64",
				"arm64"
			],
			"libc": [
				"current",
				"glibc"
			]
		},
		"onlyBuiltDependencies": [
			"@swc/core",
			"esbuild"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-conventional": "^21.2.0",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@vitejs/plugin-react-swc": "catalog:",
		"commitizen": "^4.3.2",
		"cz-git": "^1.13.1",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"npm-check-updates": "^22.2.9",
		"typescript": "catalog:",
		"vite": "catalog:"
	}
}
